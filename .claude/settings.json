{
  "env": {
    "METADATA_SERVER_DETECTION": "bios-only"
  },
  "permissions": {
    "defaultMode": "auto"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/pre-commit-guard.sh",
            "timeout": 15,
            "statusMessage": "Running pre-commit checks..."
          }
        ]
      }
    ]
  }
}
